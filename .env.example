# FundAdministration 环境变量模板。复制为 .env 后填写。

# 数据库：默认自包含 SQLite（推荐，便于独立备份/交接）。
# 也可指向独立 MySQL 实例：mysql+pymysql://user:pwd@host:3306/fundadmin?charset=utf8mb4
FUND_DB_URL=sqlite:////Users/anzhi/FundAdministration/data/fundadmin.db

# 产物与收件箱目录（可选；缺省落到仓库内 outputs/）
FUND_INBOX_DIR=
FUND_OUTPUTS_DIR=

# IMAP（券商持仓 Excel 邮件抓取）。客户净值通知的 SMTP 默认复用此账号，
# 走 smtp.exmail.qq.com:465（可用 notify-clients 的 --smtp-* 覆盖）。
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_MAILBOX=INBOX

# SMTP（内部组合汇总邮件发送：build / sync-latest 的产品汇总邮件）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# 可选：一次性从 MySQL projectx.x_cust_rpt 导入客户清单（需 pip install -e ".[mysql]"）
PROJECTX_DB_URL=
